{
  "info": {
    "name": "Explore With Me - Feature: location processing",
    "description": "Базовые тесты дополнительной функциональности: администрирование локаций и поиск событий в локации.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Создание локации",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.collectionVariables.set('locName', 'Location ' + Date.now());"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ответ должен содержать код статуса 201 и данные в формате json', function () {",
              "    pm.response.to.have.status(201);",
              "    pm.response.to.be.json;",
              "});",
              "const body = pm.response.json();",
              "pm.collectionVariables.set('locId', body.id);",
              "pm.test('В ответе есть id и переданные поля', function () {",
              "    pm.expect(body.id).to.not.be.undefined;",
              "    pm.expect(body.name).to.eql(pm.collectionVariables.get('locName'));",
              "    pm.expect(body.radius).to.eql(20);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"{{locName}}\",\n    \"lat\": 55.751244,\n    \"lon\": 37.618423,\n    \"radius\": 20\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/locations",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "locations"]
        }
      }
    },
    {
      "name": "Создание локации с пустым именем",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ответ должен содержать код статуса 400', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"\",\n    \"lat\": 55.75,\n    \"lon\": 37.62,\n    \"radius\": 10\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/locations",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "locations"]
        }
      }
    },
    {
      "name": "Создание локации с неположительным радиусом",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ответ должен содержать код статуса 400', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"name\": \"Bad radius\",\n    \"lat\": 55.75,\n    \"lon\": 37.62,\n    \"radius\": 0\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/locations",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "locations"]
        }
      }
    },
    {
      "name": "Получение списка локаций",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ответ должен содержать код статуса 200 и массив', function () {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/locations",
          "host": ["{{baseUrl}}"],
          "path": ["locations"]
        }
      }
    },
    {
      "name": "Получение локации по идентификатору",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ответ должен содержать код статуса 200 и запрошенную локацию', function () {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(pm.response.json().id).to.eql(pm.collectionVariables.get('locId'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/locations/{{locId}}",
          "host": ["{{baseUrl}}"],
          "path": ["locations", "{{locId}}"]
        }
      }
    },
    {
      "name": "Получение несуществующей локации",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ответ должен содержать код статуса 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/locations/999999",
          "host": ["{{baseUrl}}"],
          "path": ["locations", "999999"]
        }
      }
    },
    {
      "name": "Обновление локации",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ответ должен содержать код статуса 200 и обновлённый радиус', function () {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(pm.response.json().radius).to.eql(35);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"radius\": 35\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/admin/locations/{{locId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "locations", "{{locId}}"]
        }
      }
    },
    {
      "name": "Получение событий в локации",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ответ должен содержать код статуса 200 и массив событий', function () {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(pm.response.json()).to.be.an('array');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/locations/{{locId}}/events",
          "host": ["{{baseUrl}}"],
          "path": ["locations", "{{locId}}", "events"]
        }
      }
    },
    {
      "name": "Удаление локации",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ответ должен содержать код статуса 204', function () {",
              "    pm.response.to.have.status(204);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/admin/locations/{{locId}}",
          "host": ["{{baseUrl}}"],
          "path": ["admin", "locations", "{{locId}}"]
        }
      }
    },
    {
      "name": "Получение удалённой локации",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Ответ должен содержать код статуса 404', function () {",
              "    pm.response.to.have.status(404);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/locations/{{locId}}",
          "host": ["{{baseUrl}}"],
          "path": ["locations", "{{locId}}"]
        }
      }
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8080"}
  ]
}
